{
  "name": "basecamp-clone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "dropbox:refresh-token": "node scripts/get-dropbox-refresh-token.mjs",
    "seed:dummy-projects": "node --env-file=.env.local scripts/seed-dummy-projects.mjs",
    "migrate:active": "npx tsx scripts/migrate-bc2.ts --mode=full --projects=active --files",
    "backfill:bc2-file-linkage": "npx tsx scripts/backfill-bc2-file-linkage.ts",
    "db:reset-bc2-data": "npx tsx scripts/reset-bc2-import-data.ts --yes"
  },
  "dependencies": {
    "@mdxeditor/editor": "^3.52.5",
    "@supabase/supabase-js": "^2.54.0",
    "@types/nodemailer": "^7.0.11",
    "dropbox": "^10.34.0",
    "marked": "^13.0.2",
    "next": "^15.2.4",
    "nodemailer": "^8.0.3",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.13.0",
    "slugify": "^1.6.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "22.19.17",
    "@types/pg": "^8.11.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.13.0",
    "bcryptjs": "^3.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.2.4",
    "typescript": "5.9.3",
    "vitest": "^2.1.9"
  }
}
