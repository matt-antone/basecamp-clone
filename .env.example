BASECAMP_ACCOUNT_ID=999999999
BASECAMP_AUTH_MODE=basic
BASECAMP_USERNAME=you@example.com
BASECAMP_PASSWORD=your-password-or-token
BASECAMP_USER_AGENT=Basecamp MCP Server (you@example.com)
BASECAMP_CACHE_TTL_MS=30000
BASECAMP_DEFAULT_LIMIT=20
BASECAMP_DEFAULT_HOURS=168
# Optional: further narrow scope beyond starred projects.
# BASECAMP_ALLOWED_PROJECT_IDS=12345,67890
# Optional: local override for testing.
# BASECAMP_BASE_URL=http://127.0.0.1:4010/999999999/api/v1
# Optional: directory for resolving relative attachment paths (default: process cwd).
# BASECAMP_ATTACHMENTS_CWD=/path/to/your/workspace
# Optional: port for HTTP/SSE server (default: 3847). Used when running npm run serve.
# MCP_PORT=3847
# Optional: export pipeline defaults.
# BASECAMP_EXPORT_OUTPUT_DIR=./exports
# BASECAMP_EXPORT_MAX_CONCURRENCY=4
# BASECAMP_EXPORT_DOWNLOAD_TIMEOUT_MS=10000
# BASECAMP_EXPORT_INCLUDE_STATUSES=active,archived,trashed
