DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
WORKSPACE_DOMAIN=yourcompany.com
EMAIL_ENABLED=true
EMAIL_FROM=notifications@yourcompany.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_SELECT_USER=
DROPBOX_SELECT_ADMIN=
DROPBOX_PROJECTS_ROOT_FOLDER=/projects
# Origin only. Example: https://thumbs.example.internal
# Do not include /thumbnails or any other path suffix.
THUMBNAIL_WORKER_URL=
THUMBNAIL_WORKER_TOKEN=
THUMBNAIL_WORKER_TIMEOUT_MS=15000

# ─── MCP Server ──────────────────────────────────────────────────────────────
# Admin keys (at least one required to bootstrap first agent_clients row)
MCP_ACCESS_KEY=
MCP_ACCESS_KEYS=

# Rate limiting — requests per minute per agent (default: 120)
MCP_RATE_LIMIT_RPM=120

# Agent credentials are stored in the agent_clients DB table.
# To add an agent, insert a row with a bcrypt-hashed secret:
#   insert into agent_clients (client_id, secret_hash, role)
#   values ('mcp-test-client', crypt('your-secret', gen_salt('bf')), 'agent');
# Note: requires pgcrypto extension (already enabled in migration 0001).

# ─── Integration Smoke Test ───────────────────────────────────────────────────
MCP_SMOKE_URL=
MCP_SMOKE_CLIENT_ID=
MCP_SMOKE_SECRET=

# Basecamp 2 Migration
BC2_ACCOUNT_ID=          # numeric account ID from basecamp.com/{id}/api/v1
BC2_ACCESS_TOKEN=        # personal access token from Basecamp → My Profile → Access Tokens
BC2_USER_AGENT=          # required by BC2 API: "AppName (you@domain.com)"
BC2_REQUEST_DELAY_MS=200 # ms between requests (default 200)
