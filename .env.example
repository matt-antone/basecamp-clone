DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
WORKSPACE_DOMAIN=yourcompany.com
EMAIL_ENABLED=true
EMAIL_FROM=notifications@yourcompany.com
MAILGUN_EMAIL=notifications@yourcompany.com
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_SELECT_USER=
DROPBOX_SELECT_ADMIN=
DROPBOX_PROJECTS_ROOT_FOLDER=
DROPBOX_ARCHIVED_CLIENTS_ROOT=
# Vercel Blob (transient storage for file upload bypass; auto-injected on Vercel)
BLOB_READ_WRITE_TOKEN=
# Origin only. Example: https://thumbs.example.internal
# Do not include /thumbnails or any other path suffix.
THUMBNAIL_WORKER_URL=
THUMBNAIL_WORKER_TOKEN=
THUMBNAIL_WORKER_TIMEOUT_MS=15000

# ─── MCP Server (canonical) ─────────────────────────────────────────────────
# JWT auth for the basecamp-mcp edge function
PM_SERVER_JWT_SECRET=
PM_SERVER_JWT_ISSUER=basecamp-mcp
PM_SERVER_JWT_AUDIENCE=basecamp-mcp
PM_SERVER_JWT_CLOCK_TOLERANCE_SECONDS=30

# Basecamp MCP pi extension (canonical)
PM_CLIENT_MCP_URL=
PM_CLIENT_ID=
PM_CLIENT_JWT_SECRET=
PM_CLIENT_JWT_ISSUER=basecamp-mcp
PM_CLIENT_JWT_AUDIENCE=basecamp-mcp

# Rate limiting — requests per minute per agent (default: 120)
MCP_RATE_LIMIT_RPM=120

# Agent credentials are stored in the agent_clients DB table.
# To add an agent, insert a row with a bcrypt-hashed secret and mint a short-lived JWT
# whose sub matches the client_id.
# The client_id used by the extension must already exist in agent_clients.

# ─── Integration Smoke Test ───────────────────────────────────────────────────
MCP_SMOKE_URL=
MCP_SMOKE_JWT=

# Basecamp 2 Migration
BASECAMP_ACCOUNT_ID=     # numeric account ID from basecamp.com/{id}/api/v1
BASECAMP_AUTH_MODE=basic # "basic" (username/password) is the only supported mode
BASECAMP_USERNAME=       # Basecamp login email
BASECAMP_PASSWORD=       # Basecamp login password
BASECAMP_USER_AGENT=     # required by BC2 API: "AppName (you@domain.com)"
BASECAMP_REQUEST_DELAY_MS=200 # ms between requests (default 200)
